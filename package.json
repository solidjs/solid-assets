{
  "name": "solid-assets",
  "description": "Official assets for the SolidJS community",
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist/worker.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/solidjs/solid-assets"
  },
  "private": true,
  "scripts": {
    "dev": "vpc dev src/worker.ts",
    "build": "tsc && vpc build -m src/worker.ts dist/worker.js",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "deploy": "pnpm build && vitest run && wrangler deploy",
    "scripts:generate-fonts": "vite-node scripts/generate-fonts.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/opentype.js": "^1.3.3",
    "miniflare": "^2.3.0",
    "typescript": "^4.5.4",
    "vite": "^7.3.2",
    "vite-node": "^3.2.4",
    "vite-plugin-cloudflare": "0.1.3",
    "vite-raw-plugin": "^1.0.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "opentype.js": "^1.3.4"
  },
  "engines": {
    "node": ">=16.7"
  },
  "packageManager": "pnpm@10.33.3"
}